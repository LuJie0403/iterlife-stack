# IterLife deploy webhook environment example
# Real runtime path on server:
#   /apps/config/iterlife-reunion-stack/iterlife-deploy-webhook.env
# API service naming convention:
#   use no suffix: iterlife-reunion / iterlife-expenses
# UI service naming convention:
#   use -ui suffix: iterlife-reunion-ui / iterlife-expenses-ui
WEBHOOK_BIND_HOST=127.0.0.1
WEBHOOK_BIND_PORT=19091
WEBHOOK_PATH=/hooks/app-deploy
WEBHOOK_SECRET=CHANGE_ME
DEPLOY_TARGETS_JSON={"iterlife-reunion":{"deploy_script":"/apps/iterlife-reunion/deploy/scripts/deploy-reunion-from-ghcr.sh","image_env":"API_IMAGE_REF"},"iterlife-reunion-ui":{"deploy_script":"/apps/iterlife-reunion-ui/deploy/scripts/deploy-reunion-ui-from-ghcr.sh","image_env":"UI_IMAGE_REF"},"iterlife-expenses":{"deploy_script":"/apps/iterlife-expenses/deploy-expenses-api-from-ghcr.sh","image_env":"API_IMAGE_REF"},"iterlife-expenses-ui":{"deploy_script":"/apps/iterlife-expenses/deploy-expenses-ui-from-ghcr.sh","image_env":"UI_IMAGE_REF"}}
DEPLOY_TIMEOUT_SECONDS=600
WEBHOOK_LOG_DIR=/apps/logs/webhook
WEBHOOK_LOG_FILE_PREFIX=iterlife-deploy-webhook
GHCR_REGISTRY=ghcr.io
# Prefer reusing the host's docker login session instead of storing a long-lived
# registry token in plaintext here. If a temporary token is unavoidable, place it
# in a separate root-owned secret file and rotate it regularly.
