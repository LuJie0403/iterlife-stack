# IterLife deploy webhook environment example
# Real runtime path on server:
#   /apps/config/iterlife-stack/iterlife-deploy-webhook.env
# Service naming convention:
#   API services use -api suffix
#   UI services use -ui suffix
WEBHOOK_BIND_HOST=127.0.0.1
WEBHOOK_BIND_PORT=19091
WEBHOOK_PATH=/hooks/app-deploy
WEBHOOK_SECRET=CHANGE_ME
DEPLOY_TARGETS_FILE=/apps/iterlife-stack/config/deploy-targets.json
DEPLOY_EXECUTOR_SCRIPT=/apps/iterlife-stack/scripts/deploy-service-from-ghcr.sh
DEPLOY_TIMEOUT_SECONDS=600
WEBHOOK_LOG_DIR=/apps/logs/webhook
WEBHOOK_LOG_FILE_PREFIX=iterlife-deploy-webhook
GHCR_REGISTRY=ghcr.io
# Prefer reusing the host's docker login session instead of storing a long-lived
# registry token in plaintext here. If a temporary token is unavoidable, place it
# in a separate root-owned secret file and rotate it regularly.
